# ==========================================================
# Plantilla de variables de entorno - Backend Farmacia
# Copia este archivo a .env y rellena los valores.
#   cp .env.example .env
# Genera SECRET_KEY con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# ==========================================================

DEBUG=True
SECRET_KEY=cambia-esta-clave-por-una-secreta
ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL ---
DB_NAME=farmacia_db
DB_USER=postgres
DB_PASSWORD=tu_password
DB_HOST=localhost
DB_PORT=5432

# --- CORS (frontend Angular) ---
CORS_ALLOWED_ORIGINS=http://localhost:4200

# --- JWT (minutos / dias) ---
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=1
